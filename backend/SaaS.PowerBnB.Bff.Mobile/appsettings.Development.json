{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp.ReverseProxy": "Debug"
    }
  },

  "OpenTelemetry": {
    "ServiceName": "SaaS.PowerBnB.Bff",
    "Endpoint": "http://127.0.0.1:4317"
  },

  "Authentication": {
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/powerbnb",
      "MetadataAddress": "http://localhost:8080/realms/powerbnb/.well-known/openid-configuration",
      "Audience": "powerbnb-api",
      "RequireHttpsMetadata": "false", // Obrigatório ser false para ambiente local (HTTP)
      "ValidIssuers": [
        "http://localhost:8080/realms/powerbnb",
        "http://10.0.2.2:8080/realms/powerbnb"
      ]
    }
  },

  "ReverseProxy": {
    "Routes": {

      "charging-route": {
        "ClusterId": "charging-point-api",
        "AuthorizationPolicy": "bffPolicy",
        "Match": {
          "Path": "/bff/charging/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },

      "telemetry-route": {
        "ClusterId": "telemetry-cluster",
        // Usamos "anonymous" para que o Flutter consiga enviar os rastros 
        // mesmo se o usuário ainda não estiver logado no app!
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/v1/traces"
        }
      }
    },

    "Clusters": {
    
      "charging-point-api": {
        "Destinations": {
          "internalMonolith": {
            "Address": "http://localhost:5046"
          }
        }
      },
      
      "telemetry-cluster": {
        "Destinations": {
          "jaeger-http": {
            // ATENÇÃO À PORTA: 4318 é a porta padrão para receber OTLP via HTTP.
            // (A porta 4317 que o .NET usa no Program.cs é para gRPC).
            "Address": "http://127.0.0.1:4318"
          }
        }
      }
    }
  }
}
