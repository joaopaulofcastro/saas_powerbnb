{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Authentication": {
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/powerbnb",
      "MetadataAddress": "http://localhost:8080/realms/powerbnb/.well-known/openid-configuration",
      "Audience": "powerbnb-app",
      "RequireHttpsMetadata": "false" // Obrigatório ser false para ambiente local (HTTP)
    }
  },

  "ReverseProxy": {
    "Routes": {
      "chargingRoute": {
        "ClusterId": "monolithCluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/bff/charging/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "monolithCluster": {
        "Destinations": {
          "internalMonolith": {
            "Address": "http://localhost:5046/api/charging-points"
          }
        }
      }
    }
  }
}
